# Copy to .env on VPS: cp .env.production.example .env

# โดเมนที่ชี้มาที่ IP ของ VPS (ต้องอยู่ใน DNS แล้ว)
DOMAIN=erp.yourdomain.com

# อีเมลสำหรับ Let's Encrypt (Caddy)
ACME_EMAIL=you@yourdomain.com

# ใช้ใน container อัตโนมัติผ่าน docker-compose.yml
DATABASE_URL=file:/data/prod.db
NODE_ENV=production
