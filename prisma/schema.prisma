generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model DataRecord {
  sheet     String
  recordId  String
  data      Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@id([sheet, recordId])
  @@index([sheet])
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
